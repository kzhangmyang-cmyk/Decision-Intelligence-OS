APP_NAME="Decision Intelligence OS Backend"
ENVIRONMENT="local"
DEBUG="true"
VERSION="0.1.0"

API_V1_PREFIX="/api/v1"
DOCS_URL="/docs"
REDOC_URL="/redoc"

DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/decision_os"
SQL_ECHO="false"

CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
CORS_ALLOW_CREDENTIALS="true"
CORS_ALLOW_METHODS="GET,POST,PUT,PATCH,DELETE,OPTIONS"
CORS_ALLOW_HEADERS="*"
